---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="card-container">
				<h1>👋 Hello there!</h1>
				<div class="card-content">
					<p>
						Welcome to my personal blog. I'm <strong>Alex Mak</strong>, a Full Stack Engineer.
					</p>
					<p>
						I use this blog to document my journey of mastering coding skills and advancing in software engineering. Here, you'll find articles where I share what I've learned, the technical challenges I've encountered, and the practical solutions I've discovered along the way.
					</p>
					<p>
						Whether it's exploring new frameworks, diving deep into backend architecture, or solving tricky bugs, my goal is to share knowledge that might help others in the developer community.
					</p>
					<p>
						Feel free to check out my <a href="/blog">blog posts</a> or learn more <a href="/about">about me</a>!
					</p>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
